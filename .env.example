# Supabase Configuration
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Flask Security Configuration
# IMPORTANT: Generate a strong secret key for production!
# Use: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_generated_secret_key_here

# Environment
FLASK_ENV=development

# Email Configuration (SendGrid - Works on Render/Heroku/Vercel)
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDER_EMAIL=noreply@yourdomain.com

# Interswitch Payment Gateway (Sandbox)
ISW_CLIENT_ID=your_client_id_here
ISW_SECRET_KEY=your_secret_key_here
ISW_MERCHANT_CODE=your_merchant_code_here
ISW_PAY_ITEM_ID=your_pay_item_id_here
ISW_ENV=SANDBOX

# Production Settings (uncomment for production)
# FLASK_ENV=production
# SESSION_COOKIE_SECURE=True
# FORCE_HTTPS=True
